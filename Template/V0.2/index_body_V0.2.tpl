<script>//initial status: audio is not playing
var status = false;
var audio = document.getElementById("audio-player");

function audioHandler(){
  if(status == false || audio.paused){
    audio.play();
    status = true;
  }else{
    audio.pause();
    status = false;
  }
}</script>

